{
  "name": "@mingxy/cerebro",
  "version": "2.0.1",
  "description": "Cerebro persistent memory plugin for OpenCode — auto-recall, auto-capture, 9 memory tools with clustering, project-scoped memory isolation",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tui": {
      "types": "./src/tui.tsx",
      "default": "./src/tui.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "build:web": "bash ../../scripts/build-plugin-web.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build:web && npx tsc --noEmit -p tsconfig.publish.json"
  },
  "keywords": [
    "opencode",
    "memory",
    "ai-agent",
    "persistent-memory",
    "cerebro",
    "clustering",
    "project-isolation"
  ],
  "author": "mingxy-cerebro",
  "files": [
    "src/",
    "web/"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/mingxy-cerebro/cerebro-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/mingxy-cerebro/cerebro-server.git",
    "directory": "plugins/opencode"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.162",
    "@opentui/core": "^0.1.92",
    "@opentui/solid": "^0.1.92",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
